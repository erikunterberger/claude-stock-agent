# --- Market data (Financial Modeling Prep) ---
# Sign up: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# --- News (NewsAPI) ---
# Sign up: https://newsapi.org/register
NEWSAPI_KEY=

# --- Analysis (Google Gemini, free tier via AI Studio) ---
# Sign up: https://aistudio.google.com/apikey (no credit card required)
GEMINI_API_KEY=
ANALYSIS_MODEL=gemini-2.5-flash

# --- Email delivery (optional, only needed if you run with --email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
